{
  "manifest_version": 3,
  "name": "Google Forms Timer",
  "version": "1.0.0",
  "description": "A customizable timer for Google Forms",
  "permissions": [
    "storage",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://docs.google.com/forms/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Timer Settings"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-C5mKAZTE.js"
      ],
      "matches": [
        "*://docs.google.com/forms/*"
      ],
      "css": [
        "assets/content-CuUaw2Ql.css"
      ]
    },
    {
      "js": [
        "assets/dashboard-sync.ts-BU-HPvCk.js"
      ],
      "matches": [
        "http://localhost:5173/*",
        "https://forms.tapopen.online/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://docs.google.com/*"
      ],
      "resources": [
        "assets/index-CEBZVaHV.js",
        "assets/content.ts-Q0uuAdKh.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "https://forms.tapopen.online/*"
      ],
      "resources": [
        "assets/dashboard-sync.ts-BU-HPvCk.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
